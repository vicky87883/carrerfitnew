{
  "name": "carrerfit-com",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "concurrently -k -n WEB,API -c blue,magenta \"next dev\" \"tsx watch server/index.ts\"",
    "dev:web": "next dev",
    "dev:api": "tsx watch server/index.ts",
    "build": "npm run build:api && next build",
    "build:api": "tsc -p tsconfig.server.json",
    "start": "node dist/server/production.js",
    "start:api": "node dist/server/index.js",
    "test": "npm run typecheck && npm run test:matcher",
    "test:matcher": "tsx scripts/test-matcher.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "next": "^15.1.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.2.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.7.2"
  }
}
