GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
WEB_URL=http://localhost:3000
API_PORT=4000
API_URL=http://localhost:4000
CARRERFIT_DATA_DIR=./server/data
CARRERFIT_DB_PATH=./server/data/carrerfit.sqlite
# Hostinger MySQL/MariaDB (when all four are set, MySQL replaces SQLite)
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=false
DB_POOL_SIZE=5
SCRAPER_ADMIN_TOKEN=replace_with_at_least_16_random_characters
CRON_SECRET=replace_with_a_different_random_secret
BLOG_ADMIN_TOKEN=replace_with_at_least_24_random_characters

# Secure accounts. Leave AUTH_REQUIRED=false for the first deployment, configure SMTP,
# verify /api/health, then change it to true to require verified accounts.
APP_URL=http://localhost:3000
AUTH_REQUIRED=false
AUTH_SECRET=replace_with_at_least_32_random_characters
ADMIN_EMAILS=admin@carrerfit.com
ADMIN_PASSWORD=replace_with_a_unique_20_plus_character_admin_password
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@carrerfit.com
SMTP_PASSWORD=your_mailbox_password
SMTP_FROM=CarrerFit.com <no-reply@carrerfit.com>
